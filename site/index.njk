---
layout: layouts/base.njk
title: "B.T. Franklin - Software Projects"
description: "A curated showcase of B.T. Franklin's active and archived open-source software projects."
navKey: projects
---
<main class="container mx-auto px-4 pt-10 pb-12 flex-grow">
    <h1 class="sr-only">
        Projects
    </h1>

    <h2 class="text-3xl font-bold mb-8 font-mono text-zinc-800 dark:text-zinc-100 flex items-center">
        <span class="border-b-4 border-cyan-500 pb-2">Active Projects</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-24">
        {% for project in collections.activeProjects %}
        <article data-project-card
            class="bg-white/80 dark:bg-gray-800/80 backdrop-blur-md rounded-xl shadow-md border border-zinc-200 dark:border-zinc-700 overflow-hidden flex flex-col transform transition-all hover:shadow-xl hover:scale-[1.01] duration-300">
            <div class="h-64 overflow-hidden relative group">
                <img src="{{ project.data.image }}"
                    alt="{{ project.data.image_alt }}"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors"></div>
            </div>
            <div class="p-8 flex-grow flex flex-col">
                <div class="flex justify-between items-start mb-4">
                    <h2 class="text-3xl font-bold font-mono text-zinc-800 dark:text-zinc-100">
                        <a href="{{ project.data.repo_url }}" target="_blank"
                            rel="noopener noreferrer"
                            class="hover:text-cyan-500 transition-colors">{{ project.data.title }}</a>
                    </h2>
                </div>
                <div class="text-lg text-zinc-600 dark:text-gray-300 mb-6 leading-relaxed flex-grow [&_p]:mb-0">
                    {{ project.templateContent | safe }}
                </div>
                <div class="pt-4 border-t border-zinc-200 dark:border-zinc-700">
                    <span class="text-xs font-mono text-zinc-500 dark:text-zinc-400 block">Last updated in
                        {{ project.data.updated }}</span>
                </div>
            </div>
        </article>
        {% endfor %}
    </div>

    <h2 class="text-3xl font-bold mb-8 font-mono text-zinc-500 dark:text-zinc-400 flex items-center">
        <span class="border-b-4 border-zinc-300 dark:border-zinc-700 pb-2">Archived Projects</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12 opacity-80 hover:opacity-100 transition-opacity">
        {% for project in collections.archivedProjects %}
        <article data-project-card
            class="bg-zinc-100 dark:bg-zinc-900/50 backdrop-blur-md rounded-xl shadow border border-zinc-200 dark:border-zinc-800 overflow-hidden flex flex-col">
            <div class="p-6 flex-grow flex flex-col">
                <h2 class="text-xl font-bold font-mono mb-2 text-zinc-600 dark:text-zinc-300">
                    <a href="{{ project.data.repo_url }}" target="_blank" rel="noopener noreferrer"
                        class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">{{ project.data.title }}</a>
                </h2>
                <div class="text-zinc-500 dark:text-gray-500 mb-4 flex-grow text-sm [&_p]:mb-0">
                    {{ project.templateContent | safe }}
                </div>
                <div class="mt-4 pt-4 border-t border-zinc-200 dark:border-zinc-800">
                    <span class="text-xs font-mono text-zinc-400 dark:text-zinc-600 block">Last updated in
                        {{ project.data.updated }}</span>
                </div>
            </div>
        </article>
        {% endfor %}
    </div>
</main>

<script>
    const projectCards = document.querySelectorAll('[data-project-card]')
    projectCards.forEach((card) => {
        const link = card.querySelector('a[href]')
        if (!link) {
            return
        }
        card.addEventListener('click', (event) => {
            if (event.target.closest('a')) {
                return
            }
            link.click()
        })
    })
</script>
