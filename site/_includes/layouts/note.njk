---
layout: layouts/base.njk
navKey: notes
---
<main class="container mx-auto px-4 pt-10 pb-16 flex-grow">
    <article
        class="border border-zinc-200 dark:border-zinc-800 bg-white/85 dark:bg-gray-900/80 backdrop-blur-sm rounded-lg shadow-2xl p-6 md:p-8">
        <a href="/notes/"
            class="font-mono text-sm uppercase tracking-widest text-cyan-600 dark:text-cyan-300 hover:text-cyan-500 transition-colors">Notes</a>
        <h1 class="mt-4 font-mono text-3xl md:text-4xl font-bold text-zinc-950 dark:text-white">{{ title }}</h1>
        {% if date %}
        <p class="mt-3 text-sm font-mono text-zinc-500 dark:text-zinc-400">{{ date | displayDate }}</p>
        {% endif %}
        <div
            class="mt-8 space-y-5 text-zinc-700 dark:text-zinc-300 leading-relaxed [&_h2]:pt-6 [&_h2]:font-mono [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-violet-600 dark:[&_h2]:text-violet-300 [&_h3]:pt-4 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-zinc-900 dark:[&_h3]:text-zinc-100 [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-6 [&_a]:text-cyan-700 dark:[&_a]:text-cyan-300 [&_a]:underline [&_code]:rounded [&_code]:bg-zinc-100 dark:[&_code]:bg-gray-800 [&_code]:px-1 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-sm [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:bg-gray-900 [&_pre]:p-4 [&_pre]:text-gray-100 [&_pre_code]:bg-transparent [&_pre_code]:p-0">
            {{ content | safe }}
        </div>
    </article>
</main>
